import { v } from "convex/values";

export default defineSchema({
  tasks: defineTable({
    title: v.string(),
    description: v.string(),
    status: v.string(),
    priority: v.number(),
    agentName: v.string(),
    acceptanceCriteria: v.string(), // The "New" required field
  }),
  logs: defineTable({
    agent: v.string(),
    action: v.string(),
    timestamp: v.number(),
    category: v.optional(v.string()),
    taskId: v.optional(v.id("tasks")),
  }),
  agents: defineTable({
    name: v.string(),
    role: v.string(),
    icon: v.string(),
    color: v.string(),
    soulPath: v.string(), // CHANGED TO OPTIONAL
  }),
});
